PORT=3000
NODE_ENV=development

# ─── Payment Gateways ──────────────────────────────────────────────────────────
# Zibal merchant ID
ZIBAL_MERCHANT=your-zibal-merchant-id

# Zarinpal merchant ID (36-char UUID)
ZARINPAL_MERCHANT=your-zarinpal-merchant-id

# SEP (Saman) terminal credentials
SEP_TERMINAL_ID=your-sep-terminal-id
SEP_USERNAME=your-sep-username
SEP_PASSWORD=your-sep-password

# ─── URLs ──────────────────────────────────────────────────────────────────────
# Base URL of THIS service — used to build gateway callback URLs
# Example: https://payment.yourdomain.com
CALLBACK_BASE_URL=https://your-payment-service.example.com

# Where to redirect the user after a successful payment
FRONT_SUCCESS_URL=https://your-app.example.com/payment/success

# Where to send the user on payment failure / back button
FRONT_BASE_URL=https://your-app.example.com

# ─── Webhooks ──────────────────────────────────────────────────────────────────
# Called (POST) by this service after a payment is verified successfully.
# Payload: { orderId, gateway, status:"success", code, verifyDetails, timestamp }
PAYMENT_SUCCESS_WEBHOOK_URL=https://your-app.example.com/webhooks/payment-success

# Called (POST) after a payment fails or is cancelled.
# Payload: { orderId, gateway, status:"failed", code, reason, timestamp }
PAYMENT_FAILURE_WEBHOOK_URL=https://your-app.example.com/webhooks/payment-failure

# Optional shared secret sent in X-Webhook-Secret header so your app can verify requests
WEBHOOK_SECRET=your-webhook-secret

# ─── Gateway Routing ───────────────────────────────────────────────────────────
# Force a specific gateway for all requests (overrides the gateway param).
# Valid values: zibal | zarinpal | sep   — leave empty to use per-request routing.
# FORCED_PAYMENT_GATEWAY=zarinpal

# Enable fail-over: if the primary gateway fails, try the next one in the chain.
# Set to "false" to disable. Defaults to enabled.
# PAYMENT_FAILOVER_ENABLED=true

# Timeout/retry tuning for the PAYMENT REQUEST phase
# GATEWAY_REQUEST_TIMEOUT_MS=8000
# GATEWAY_REQUEST_RETRIES=1
# Last-gateway (final fallback) is more patient:
# GATEWAY_LAST_TIMEOUT_MS=15000
# GATEWAY_LAST_RETRIES=2

# ─── Admin ─────────────────────────────────────────────────────────────────────
# Secret key for admin endpoints (Authorization: Bearer <key> or ?token=<key>)
ADMIN_KEY=your-admin-secret-key

# ─── Notifications (optional) ──────────────────────────────────────────────────
# Telegram — leave empty to disable
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_FAILED_BOT_TOKEN=
TELEGRAM_FAILED_CHAT_ID=
# Telegram Bot API base URL — use your own proxy if needed
# TELEGRAM_BASE_URL=https://api.telegram.org

# Bale messenger — leave empty to disable
BALE_BOT_TOKEN=
BALE_CHAT_ID=
BALE_FAILED_BOT_TOKEN=
BALE_FAILED_CHAT_ID=

# ─── Webhook Retry Queue ───────────────────────────────────────────────────────
# QUEUE_MAX_RETRIES=2880
# QUEUE_RETRY_INTERVAL_MS=60000

# ─── Session Store ─────────────────────────────────────────────────────────────
# How long to keep payment sessions (for Zarinpal amount lookup on callback)
# PAYMENT_SESSION_TTL_MS=7200000
